# Clerk — get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# PostgreSQL — Railway, Supabase, Neon, etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Server
PORT=3000

# CORS — set to your production domain when deploying
# Comma-separated if multiple: https://app.com,https://www.app.com
ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare R2 — persistent video storage (optional but recommended for production)
# Get these from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=viddly-downloads
